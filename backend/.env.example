APP_NAME="LinkedIn Automation"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://api.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# Logging — daily rotation, notice level for production
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=notice
LOG_DAILY_DAYS=30

# Database
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=linkedin_automation
DB_USERNAME=postgres
DB_PASSWORD=

# Redis — used for cache, queue, sessions in production
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Session — use redis in production
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue — use redis in production
QUEUE_CONNECTION=redis

# Cache — use redis in production
CACHE_STORE=redis
CACHE_PREFIX=linkedin_automation_

# Mail
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# LinkedIn OAuth (https://www.linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://api.yourdomain.com/api/auth/linkedin/callback

# Frontend URL (for OAuth redirect)
FRONTEND_URL=https://yourdomain.com

# CORS — comma-separated origins allowed to access the API
CORS_ALLOWED_ORIGINS=https://yourdomain.com
# Chrome extension CORS pattern (use exact extension ID)
EXTENSION_CORS_PATTERN=chrome-extension://YOUR_EXTENSION_ID

# Sanctum token expiration in minutes (43200 = 30 days)
SANCTUM_TOKEN_EXPIRATION=43200
